#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"
WORKTREE_DIR=".worktrees"
HOOKS_CONFIG=".git-wtrc"

# ── Helpers ──────────────────────────────────────────────────────────

die()     { printf '\033[1;31merror:\033[0m %s\n' "$*" >&2; exit 1; }
info()    { printf '\033[1;34m==>\033[0m %s\n' "$*" >&2; }
success() { printf '\033[1;32m✔\033[0m %s\n' "$*" >&2; }

ensure_git_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"
}

repo_root() {
  git rev-parse --show-toplevel
}

default_branch() {
  local ref
  ref="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null)" && {
    printf '%s\n' "${ref##*/}"
    return
  }
  for candidate in main master; do
    git show-ref --verify --quiet "refs/heads/$candidate" 2>/dev/null && {
      printf '%s\n' "$candidate"
      return
    }
  done
  git rev-parse --abbrev-ref HEAD
}

ensure_worktree_dir() {
  local root
  root="$(repo_root)"
  local dir="$root/$WORKTREE_DIR"

  if [ ! -d "$dir" ]; then
    mkdir -p "$dir"
    info "created $WORKTREE_DIR/"
  fi

  local gitignore="$root/.gitignore"
  if [ ! -f "$gitignore" ] || ! grep -qxF "$WORKTREE_DIR/" "$gitignore" 2>/dev/null; then
    printf '%s/\n' "$WORKTREE_DIR" >> "$gitignore"
    info "added $WORKTREE_DIR/ to .gitignore"
  fi
}

project_root() {
  local common_dir
  common_dir="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
  printf '%s\n' "${common_dir%/.git}"
}

run_hook() {
  local hook_name="$1"
  shift
  local root
  root="$(repo_root)"
  local config="$root/$HOOKS_CONFIG"

  [ -f "$config" ] || return 0

  local cmd
  cmd="$(sed -n "s/^[[:space:]]*${hook_name}[[:space:]]*=[[:space:]]*//p" "$config" | head -1)"

  [ -z "$cmd" ] && return 0

  info "running hook '$hook_name'…"
  (
    cd "$root" || exit 1
    env "$@" bash -c "eval \"\$1\"" _ "$cmd"
  ) || {
    case "$hook_name" in
      pre-*)  die "hook '$hook_name' failed — aborting" ;;
      post-*) info "hook '$hook_name' failed (non-fatal)" ;;
    esac
  }
}

# ── Per-command help ──────────────────────────────────────────────────

wants_help() {
  for arg in "$@"; do
    case "$arg" in --help|-h) return 0 ;; esac
  done
  return 1
}

usage_add() {
  cat <<EOF
Usage: git wt add <branch> [base] [--go]

Create a new worktree in $WORKTREE_DIR/<branch>.

Arguments:
  branch   Name of the branch to create
  base     Base branch (defaults to current branch)

Options:
  --go     Print the worktree path to stdout (for cd integration)

Examples:
  git wt add feature-login
  git wt add feature-login develop
  cd "\$(git wt add feature-login --go)"
EOF
}

usage_remove() {
  cat <<EOF
Usage: git wt remove <branch> [--delete-branch]

Remove an existing worktree.

Arguments:
  branch   Name of the worktree branch to remove

Options:
  --delete-branch, -db   Also delete the local branch (skip prompt)

Aliases: rm

Examples:
  git wt remove feature-login
  git wt rm feature-login
  git wt remove feature-login --delete-branch
  git wt rm feature-login -db
EOF
}

usage_list() {
  cat <<EOF
Usage: git wt list [--path]

List all worktrees in the repository.

By default, only the worktree name (branch) is shown. Use --path to also
display the absolute path after the name.

Options:
  --path   Show the worktree path after the name

Aliases: ls

Examples:
  git wt list
  git wt ls
  git wt list --path
EOF
}

usage_prune() {
  cat <<EOF
Usage: git wt prune

Remove stale worktree references that are no longer valid.

Examples:
  git wt prune
EOF
}

usage_path() {
  cat <<EOF
Usage: git wt path <branch>

Print the absolute path of a worktree.

Arguments:
  branch   Name of the worktree branch

Examples:
  git wt path feature-login
  code "\$(git wt path feature-login)"
EOF
}

usage_root() {
  cat <<EOF
Usage: git wt root

Print the absolute path of the main repository root.

Works from any worktree — always resolves to the original project directory.

Examples:
  git wt root
  cd "\$(git wt root)"
EOF
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_add() {
  local go_flag=false
  local positional=()

  for arg in "$@"; do
    case "$arg" in
      --help|-h) usage_add; return 0 ;;
      --go) go_flag=true ;;
      *) positional+=("$arg") ;;
    esac
  done

  local branch="${positional[0]:-}"
  local base="${positional[1]:-}"

  [ -z "$branch" ] && { usage_add; exit 1; }

  ensure_git_repo

  if [ -z "$base" ]; then
    base="$(git rev-parse --abbrev-ref HEAD)"
  fi

  ensure_worktree_dir

  local root
  root="$(repo_root)"
  local target="$root/$WORKTREE_DIR/$branch"

  [ -d "$target" ] && die "worktree '$branch' already exists at $WORKTREE_DIR/$branch"

  run_hook "pre-add" \
    GIT_WT_BRANCH="$branch" \
    GIT_WT_PATH="$target" \
    GIT_WT_BASE="$base" \
    GIT_WT_ROOT="$root"

  info "fetching from origin…"
  git fetch origin 2>/dev/null || info "fetch skipped (no remote 'origin')"

  info "creating worktree for '$branch' based on '$base'…"
  git worktree add -b "$branch" "$target" "$base" 2>/dev/null \
    || git worktree add "$target" "$branch" 2>/dev/null \
    || die "failed to create worktree — does branch or base exist?"

  success "worktree created at $WORKTREE_DIR/$branch"

  run_hook "post-add" \
    GIT_WT_BRANCH="$branch" \
    GIT_WT_PATH="$target" \
    GIT_WT_BASE="$base" \
    GIT_WT_ROOT="$root"

  if $go_flag; then
    printf '%s\n' "$target"
  fi
}

cmd_list() {
  wants_help "$@" && { usage_list; return 0; }

  local show_path=false
  for arg in "$@"; do
    case "$arg" in
      --path) show_path=true ;;
      *) die "unknown option: $arg" ;;
    esac
  done

  ensure_git_repo

  git worktree list --porcelain | awk -v show_path="$show_path" '
    /^worktree / { path = substr($0, 10); branch = ""; detached = 0; next }
    /^branch /   { branch = substr($0, 8); sub("^refs/heads/", "", branch); next }
    /^detached/  { detached = 1; next }
    /^$/ {
      if (path != "") {
        name = (branch != "") ? branch : (detached ? "(detached)" : path)
        if (show_path == "true") printf "%s\t%s\n", name, path
        else print name
        path = ""; branch = ""; detached = 0
      }
    }
    END {
      if (path != "") {
        name = (branch != "") ? branch : (detached ? "(detached)" : path)
        if (show_path == "true") printf "%s\t%s\n", name, path
        else print name
      }
    }
  '
}

cmd_remove() {
  local delete_branch=false
  local positional=()

  for arg in "$@"; do
    case "$arg" in
      --help|-h) usage_remove; return 0 ;;
      --delete-branch|-db) delete_branch=true ;;
      *) positional+=("$arg") ;;
    esac
  done

  local branch="${positional[0]:-}"
  [ -z "$branch" ] && { usage_remove; exit 1; }

  ensure_git_repo

  local root
  root="$(repo_root)"
  local target="$root/$WORKTREE_DIR/$branch"

  [ ! -d "$target" ] && die "worktree '$branch' not found at $WORKTREE_DIR/$branch"

  run_hook "pre-remove" \
    GIT_WT_BRANCH="$branch" \
    GIT_WT_PATH="$target" \
    GIT_WT_ROOT="$root"

  info "removing worktree '$branch'…"
  git worktree remove "$target" --force
  success "worktree '$branch' removed"

  run_hook "post-remove" \
    GIT_WT_BRANCH="$branch" \
    GIT_WT_PATH="$target" \
    GIT_WT_ROOT="$root"

  if git show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
    if $delete_branch; then
      git branch -D "$branch"
      success "branch '$branch' deleted"
    elif { true </dev/tty; } 2>/dev/null; then
      printf '\033[1;33m?\033[0m  delete local branch '\''%s'\'' as well? [y/N] ' "$branch" >&2
      read -r answer </dev/tty
      case "$answer" in
        [yY]|[yY][eE][sS])
          git branch -D "$branch"
          success "branch '$branch' deleted"
          ;;
        *)
          info "branch '$branch' kept"
          ;;
      esac
    else
      info "non-interactive shell — branch '$branch' kept (use 'git branch -D $branch' to delete)"
    fi
  fi
}

cmd_prune() {
  wants_help "$@" && { usage_prune; return 0; }
  ensure_git_repo
  info "pruning stale worktrees…"
  git worktree prune --verbose
  success "done"
}

cmd_path() {
  wants_help "$@" && { usage_path; return 0; }

  local branch="${1:-}"
  [ -z "$branch" ] && { usage_path; exit 1; }

  ensure_git_repo

  local root
  root="$(repo_root)"
  local target="$root/$WORKTREE_DIR/$branch"

  [ ! -d "$target" ] && die "worktree '$branch' not found"

  printf '%s\n' "$target"
}

cmd_root() {
  wants_help "$@" && { usage_root; return 0; }
  ensure_git_repo
  project_root
}

cmd_version() {
  printf 'git-wt %s\n' "$VERSION"
}

cmd_help() {
  cat <<EOF
git-wt $VERSION — simple git worktree manager

USAGE
  git wt <command> [args]

COMMANDS
  add <branch> [base] [--go]  Create a worktree in $WORKTREE_DIR/<branch>
                               Base defaults to current branch
  list [--path]                List all worktrees (--path also shows paths)
  remove <branch> [-db]        Remove a worktree (-db deletes branch too)
  prune                        Remove stale worktree references
  path <branch>                Print the absolute path of a worktree
  root                         Print the main repository root path
  help                         Show this help message
  version                      Show version

HOOKS
  Create a $HOOKS_CONFIG file in the repo root to run commands
  on worktree events. Available hooks:
    pre-add, post-add, pre-remove, post-remove

  Each hook receives: GIT_WT_BRANCH, GIT_WT_PATH, GIT_WT_ROOT
  Add hooks also receive: GIT_WT_BASE

EXAMPLES
  git wt add feature-login
  git wt add feature-login develop
  cd "\$(git wt add feature-login --go)"
  git wt list
  git wt remove feature-login
  git wt prune
  git wt path feature-login
  cd "\$(git wt root)"
EOF
}

# ── Dispatch ─────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    add)     cmd_add "$@" ;;
    list|ls) cmd_list "$@" ;;
    remove|rm) cmd_remove "$@" ;;
    prune)   cmd_prune "$@" ;;
    path)    cmd_path "$@" ;;
    root)    cmd_root "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h) cmd_help ;;
    *) die "unknown command '$cmd' — run 'git wt help'" ;;
  esac
}

main "$@"
